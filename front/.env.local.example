# Environment variables for local development (Mode A — PartyKit dev server)
# Copy this file to .env.local and fill in values as needed.

# PartyKit dev server host — used by the frontend to connect sockets.
# Mode A (local dev): PartyKit runs on port 1999
PUBLIC_PARTYKIT_HOST=localhost:1999

# Mode B (Docker full-stack): PartyKit runs on port 1999 inside Docker
# PUBLIC_PARTYKIT_HOST=localhost:1999

# Production (Cloudflare Pages): set this in the Cloudflare dashboard
# Pages → Project → Settings → Environment variables
# PUBLIC_PARTYKIT_HOST=sommelier-arena.USERNAME.partykit.dev
